---
import Base from '../layouts/Base.astro';
import { SITE } from '../data/site';
---

<Base title="Checkout cancelled" description="Your checkout was cancelled." path="/cancel">
  <section class="section status-section">
    <div class="container status-inner">
      <div class="status-mark status-neutral" aria-hidden="true">
        <svg width="30" height="30" viewBox="0 0 24 24" fill="none">
          <path d="M12 8v5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" />
          <circle cx="12" cy="16.5" r="1.3" fill="currentColor" />
          <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8" />
        </svg>
      </div>
      <p class="eyebrow">No charge made</p>
      <h1 class="h1 status-title">Checkout cancelled.</h1>
      <p class="lead status-lead">
        No payment was taken and nothing’s lost. Your selections are still waiting whenever you’re
        ready — pick up right where you left off, or reach out if you have questions first.
      </p>
      <div class="status-actions">
        <a href="/start" class="btn">Return to checkout</a>
        <a href={`mailto:${SITE.email}`} class="btn btn-ghost">Ask a question first</a>
      </div>
      <p class="mono-note status-foot">
        Rather talk it through? Email <a href={`mailto:${SITE.email}`} class="text-link">{SITE.email}</a>
      </p>
    </div>
  </section>
</Base>

<style>
  .status-section { min-height: 70vh; display: grid; align-items: center; }
  .status-inner { max-width: 42rem; margin-inline: auto; text-align: center; display: grid; gap: 1.3rem; justify-items: center; }
  .status-mark { width: 4.5rem; height: 4.5rem; border-radius: 50%; display: grid; place-items: center; }
  .status-neutral { border: 1px solid var(--line-strong); color: var(--mute); background: var(--surface); }
  .status-title { margin-top: 0.3rem; }
  .status-lead { margin-inline: auto; }
  .status-actions { display: flex; gap: 0.9rem; flex-wrap: wrap; justify-content: center; margin-top: 0.6rem; }
  .status-foot { margin-top: 0.8rem; }
</style>
