---
import Base from '../layouts/Base.astro';
import Configurator from '../components/islands/Configurator.tsx';
---

<Base
  title="Start a project"
  description="Build your package, add capabilities, and check out securely. Premium websites for service businesses, with a design-first guarantee."
  path="/start"
>
  <section class="start-head section">
    <div class="container">
      <p class="eyebrow" data-reveal>Start a project</p>
      <h1 class="h1 start-title" data-reveal style="--reveal-delay:0.05s">Build your site, your way.</h1>
      <p class="lead start-lead" data-reveal style="--reveal-delay:0.1s">
        Choose a package, tune the scope, and check out securely. You’ll get a confirmation right
        away and a kickoff email from our team within one business day.
      </p>
    </div>
  </section>

  <section class="start-cfg">
    <div class="container">
      <Configurator client:load />
    </div>
  </section>
</Base>

<style>
  .start-head { padding-block: clamp(3.5rem, 8vw, 5.5rem) 1rem; }
  .start-title { margin-top: 1.2rem; }
  .start-lead { margin-top: 1.3rem; }
  .start-cfg { padding-block: 2.5rem clamp(4rem, 8vw, 6rem); }
</style>
