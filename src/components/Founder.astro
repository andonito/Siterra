---
const FOUNDER_IMG =
  'https://res.cloudinary.com/dhf8b2oeg/image/upload/q_auto/f_auto/v1781626783/dd48985c-8d04-4406-aae1-1ebdf2f85acf_prgdqo.png';

const CARDS = [
  {
    title: 'Founder-led quality',
    body: 'Every project is reviewed with a clear eye for design, trust, and conversion.',
  },
  {
    title: 'Built for service businesses',
    body: 'The focus is simple: make your business look like the obvious choice before the customer calls.',
  },
  {
    title: 'Systems, not just pages',
    body: 'Your site can include checkout, forms, follow-up emails, intake flows, and care plans when needed.',
  },
];
---

<section id="founder" class="section founder">
  <div class="container">
    <div class="founder-top">
      <div class="founder-media" data-reveal>
        <div class="founder-frame">
          <img
            src={FOUNDER_IMG}
            alt="Portrait of Siterra's founder"
            width="640"
            height="640"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
      <div class="founder-intro" data-reveal style="--reveal-delay:0.08s">
        <p class="eyebrow">Who's behind Siterra</p>
        <h2 class="h2">Founder-led. Service-business focused.</h2>
        <p class="lead">
          Siterra is a founder-led web studio based in Florida, built for service businesses that
          need to look sharper, earn trust faster, and turn more visitors into calls, quote
          requests, and booked jobs.
        </p>
      </div>
    </div>

    <div class="founder-cards" data-reveal style="--reveal-delay:0.16s">
      {CARDS.map((c) => (
        <div class="founder-card">
          <h3>{c.title}</h3>
          <p>{c.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .founder-top {
    display: grid;
    grid-template-columns: minmax(210px, 310px) 1fr;
    gap: clamp(1.75rem, 5vw, 3.75rem);
    align-items: center;
  }
  .founder-media {
    display: flex;
    justify-content: center;
  }
  /* Rounded, gradient-ringed frame with a soft cyan glow — premium, not a giant portrait. */
  .founder-frame {
    width: 100%;
    max-width: 310px;
    padding: 7px;
    border-radius: 22px;
    border: 1px solid var(--line);
    background: linear-gradient(150deg, var(--surface2), var(--surface));
    box-shadow: 0 26px 70px -40px rgba(0, 0, 0, 0.7), 0 0 60px -30px var(--glow-strong);
  }
  .founder-frame img {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    object-position: center;
    border-radius: 15px;
  }
  .founder-intro .lead {
    margin-top: 1.2rem;
    max-width: 44ch;
  }
  .founder-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(0.9rem, 2vw, 1.25rem);
    margin-top: clamp(2.5rem, 6vw, 3.75rem);
  }
  .founder-card {
    padding: 1.4rem 1.45rem;
    border-radius: 16px;
    border: 1px solid var(--line);
    background: var(--surface);
  }
  .founder-card h3 {
    font: 600 1.02rem var(--font-display);
    letter-spacing: -0.01em;
    margin-bottom: 0.45rem;
  }
  .founder-card p {
    color: var(--mute);
    font-size: 0.92rem;
    line-height: 1.6;
  }
  @media (max-width: 820px) {
    /* Tighter vertical rhythm on mobile so the page keeps momentum. */
    .founder {
      padding-block: 2.5rem;
    }
    .founder-top {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
    }
    /* ~13% smaller founder image on mobile only; same centered rounded frame. */
    .founder-frame {
      max-width: 200px;
    }
    .founder-intro .lead {
      margin-top: 0.85rem;
      margin-left: auto;
      margin-right: auto;
      line-height: 1.55;
    }
    .founder-cards {
      grid-template-columns: 1fr;
      text-align: left;
      margin-top: 2rem;
    }
  }
</style>
