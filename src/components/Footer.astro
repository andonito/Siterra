---
import Logo from './Logo.astro';
import { SITE } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <Logo height={30} />
        <p class="lead" style="font-size:0.95rem;margin-top:1.1rem;max-width:24rem">
          Premium websites for service businesses — built to make you the obvious choice.
        </p>
        <a href="/start" class="btn btn-sm" style="margin-top:1.5rem">Start a project</a>
      </div>

      <nav class="footer-col" aria-label="Site">
        <h2 class="footer-h">Explore</h2>
        <a href="/#work">Work</a>
        <a href="/#process">Process</a>
        <a href="/#pricing">Pricing</a>
        <a href="/#care">Care plans</a>
        <a href="/#faq">FAQ</a>
      </nav>

      <nav class="footer-col" aria-label="Get started">
        <h2 class="footer-h">Get started</h2>
        <a href="/start">Build a site</a>
        <a href="/quote">Free Site Blueprint</a>
        <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </nav>

      <nav class="footer-col" aria-label="Legal">
        <h2 class="footer-h">Legal</h2>
        <a href="/terms">Terms</a>
        <a href="/privacy">Privacy</a>
        <a href="/refunds">Refunds & guarantee</a>
      </nav>
    </div>

    <div class="footer-bottom">
      <p class="mono-note">
        <span id="studio-trigger" role="button" tabindex="-1" title="Siterra">&copy;</span>
        {year} {SITE.name} · Built in Florida
      </p>
      <p class="mono-note">Designed &amp; built by Siterra</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--line);
    background: var(--bg2);
    padding-block: clamp(3rem, 6vw, 4.5rem) 2.5rem;
  }
  .footer-top {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--line);
  }
  .footer-brand :global(svg) {
    color: var(--ink);
  }
  .footer-col {
    display: grid;
    gap: 0.85rem;
    align-content: start;
  }
  .footer-h {
    font: 500 0.7rem var(--font-mono);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--mute);
    margin-bottom: 0.2rem;
  }
  .footer-col a {
    font: 400 0.92rem var(--font-body);
    color: var(--ink);
    text-decoration: none;
    transition: color 0.2s ease;
    width: fit-content;
  }
  .footer-col a:hover {
    color: var(--accent);
  }
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 2rem;
    flex-wrap: wrap;
  }
  #studio-trigger {
    cursor: default;
    user-select: none;
  }
  @media (max-width: 820px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
      gap: 2rem 1.5rem;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 460px) {
    .footer-top {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Hidden Style Studio trigger: 5 clicks on the © glyph, or ?studio in URL.
  const params = new URLSearchParams(window.location.search);
  if (params.has('studio')) {
    window.dispatchEvent(new CustomEvent('siterra:studio-open'));
  }
  const trigger = document.getElementById('studio-trigger');
  let clicks = 0;
  let timer: ReturnType<typeof setTimeout> | undefined;
  trigger?.addEventListener('click', () => {
    clicks += 1;
    clearTimeout(timer);
    timer = setTimeout(() => (clicks = 0), 1200);
    if (clicks >= 5) {
      clicks = 0;
      window.dispatchEvent(new CustomEvent('siterra:studio-open'));
    }
  });
</script>
