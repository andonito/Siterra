---
import Logo from './Logo.astro';

const links = [
  { href: '/#work', label: 'Work' },
  { href: '/#process', label: 'Process' },
  { href: '/#pricing', label: 'Pricing' },
  { href: '/#faq', label: 'FAQ' },
];
---

<header id="nav" class="nav">
  <div class="container nav-inner">
    <a href="/" class="nav-logo" aria-label="Siterra home">
      <Logo height={28} />
    </a>

    <nav class="nav-links" aria-label="Primary">
      {links.map((l) => (
        <a href={l.href}>{l.label}</a>
      ))}
    </nav>

    <div class="nav-cta">
      <a href="/quote" class="nav-quote">Free blueprint</a>
      <a href="/start" class="btn btn-sm">Start a project</a>
    </div>

    <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-mobile">
      <span></span><span></span>
    </button>
  </div>

  <div id="nav-mobile" class="nav-mobile" hidden>
    <div class="container">
      {links.map((l) => (
        <a href={l.href}>{l.label}</a>
      ))}
      <a href="/quote">Free blueprint</a>
      <a href="/start" class="btn btn-block">Start a project</a>
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid transparent;
    transition: background-color 0.3s ease, border-color 0.3s ease, backdrop-filter 0.3s ease;
  }
  .nav.is-stuck {
    background: color-mix(in oklab, var(--bg) 78%, transparent);
    backdrop-filter: blur(14px) saturate(1.4);
    border-bottom-color: var(--line);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 4.6rem;
  }
  .nav-logo {
    color: var(--ink);
    flex: none;
  }
  .nav-links {
    display: flex;
    gap: 1.9rem;
    margin-inline: auto;
  }
  .nav-links a {
    font: 500 0.9rem var(--font-body);
    color: var(--mute);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .nav-links a:hover {
    color: var(--ink);
  }
  .nav-cta {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    flex: none;
  }
  .nav-quote {
    font: 500 0.9rem var(--font-body);
    color: var(--ink);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .nav-quote:hover {
    color: var(--accent);
  }
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--ink);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .nav-toggle[aria-expanded='true'] span:first-child {
    transform: translateY(3.25px) rotate(45deg);
  }
  .nav-toggle[aria-expanded='true'] span:last-child {
    transform: translateY(-3.25px) rotate(-45deg);
  }
  .nav-mobile {
    border-bottom: 1px solid var(--line);
    background: var(--bg2);
    padding-block: 1.25rem;
  }
  .nav-mobile .container {
    display: grid;
    gap: 1rem;
  }
  .nav-mobile a:not(.btn) {
    font: 500 1rem var(--font-body);
    color: var(--ink);
    text-decoration: none;
    padding-block: 0.35rem;
  }
  @media (max-width: 860px) {
    .nav-links,
    .nav-cta {
      display: none;
    }
    .nav-toggle {
      display: flex;
    }
  }
</style>

<script>
  const nav = document.getElementById('nav');
  const onScroll = () => nav?.classList.toggle('is-stuck', window.scrollY > 12);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const toggle = document.querySelector('.nav-toggle');
  const mobile = document.getElementById('nav-mobile');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    if (mobile) mobile.hidden = open;
  });
  mobile?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      if (mobile) mobile.hidden = true;
    })
  );
</script>
