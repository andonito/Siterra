---
import Base from '../layouts/Base.astro';
export interface Props {
  title: string;
  updated: string;
  path: string;
  description?: string;
}
const { title, updated, path, description } = Astro.props;
---

<Base title={title} path={path} description={description}>
  <section class="section legal">
    <div class="container legal-inner">
      <header class="legal-head">
        <p class="eyebrow">Legal</p>
        <h1 class="h1 legal-title">{title}</h1>
        <p class="mono-note">Last updated {updated}</p>
      </header>

      <div class="prose">
        <slot />
      </div>
    </div>
  </section>
</Base>

<style>
  .legal { padding-block: clamp(3.5rem, 8vw, 5.5rem); }
  .legal-inner { max-width: 46rem; }
  .legal-head { display: grid; gap: 0.7rem; margin-bottom: 2rem; }
  .legal-title { margin-top: 0.6rem; }
</style>
